DATABASE_URL=postgresql://user:password@localhost:5432/mis_finanzas
GEMINI_API_KEY=tu-api-key-de-google-ai-studio
GEMINI_MODEL=gemini-3.1-flash-lite-preview;gemini-2.5-flash

# ──────────────────────────────────────────────────────
# Integración con Google Calendar
# ──────────────────────────────────────────────────────
# Clave de cifrado para refresh tokens en DB (32 bytes base64).
# Generar con: openssl rand -base64 32
ENCRYPTION_KEY=

# Cliente OAuth de Google para Calendar (separado del de Supabase Auth).
# Crear en https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integraciones/google/oauth-callback

# URL pública de la app (para deep links en eventos de calendar).
# También se usa como origin permitido por el middleware CORS (server/middleware/01.cors.js).
APP_PUBLIC_URL=http://localhost:3000

# ──────────────────────────────────────────────────────
# CORS — orígenes adicionales permitidos por el backend
# ──────────────────────────────────────────────────────
# Lista separada por comas. Solo necesario si la PWA se sirve desde
# dominios distintos a APP_PUBLIC_URL (ej. preview deploys, dominio
# corporativo + dominio .vercel.app). En dev se permite localhost
# automáticamente.
# Ejemplo: ALLOWED_ORIGINS=https://app.mifinanzas.com,https://preview-xyz.vercel.app
ALLOWED_ORIGINS=

# ──────────────────────────────────────────────────────
# Rate limiting — confianza en proxy upstream
# ──────────────────────────────────────────────────────
# Si la app corre detrás de un proxy de confianza que setea
# x-forwarded-for con la IP real del cliente (Vercel, Cloudflare,
# nginx que strippa el header del cliente), poner '1' para que el
# rate-limit por IP use ese valor. Si corres bare (docker -p directo,
# stand-alone) déjalo en '0' para que se ignore el header y se use
# socket.remoteAddress — así un atacante no puede spoofear IPs.
# Default: '1' cuando NODE_ENV=production, '0' en dev.
# TRUST_PROXY=1
