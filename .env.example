DATABASE_URL=postgresql://user:password@localhost:5432/mis_finanzas
GEMINI_API_KEY=tu-api-key-de-google-ai-studio
GEMINI_MODEL=gemini-3.1-flash-lite-preview;gemini-2.5-flash

# ──────────────────────────────────────────────────────
# Integración con Google Calendar
# ──────────────────────────────────────────────────────
# Clave de cifrado para refresh tokens en DB (32 bytes base64).
# Generar con: openssl rand -base64 32
ENCRYPTION_KEY=

# Cliente OAuth de Google para Calendar (separado del de Supabase Auth).
# Crear en https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integraciones/google/oauth-callback

# URL pública de la app (para deep links en eventos de calendar).
# También se usa como origin permitido por el middleware CORS (server/middleware/01.cors.js).
APP_PUBLIC_URL=http://localhost:3000

# ──────────────────────────────────────────────────────
# CORS — orígenes adicionales permitidos por el backend
# ──────────────────────────────────────────────────────
# Lista separada por comas. Solo necesario si la PWA se sirve desde
# dominios distintos a APP_PUBLIC_URL (ej. preview deploys, dominio
# corporativo + dominio .vercel.app). En dev se permite localhost
# automáticamente.
# Ejemplo: ALLOWED_ORIGINS=https://app.mifinanzas.com,https://preview-xyz.vercel.app
ALLOWED_ORIGINS=

# ──────────────────────────────────────────────────────
# Rate limiting — confianza en proxy upstream
# ──────────────────────────────────────────────────────
# Si la app corre detrás de un proxy de confianza que setea
# x-forwarded-for con la IP real del cliente (Vercel, Cloudflare,
# nginx que strippa el header del cliente), poner '1' para que el
# rate-limit por IP use ese valor. Si corres bare (docker -p directo,
# stand-alone) déjalo en '0' para que se ignore el header y se use
# socket.remoteAddress — así un atacante no puede spoofear IPs.
# Default: '1' cuando NODE_ENV=production, '0' en dev.
# TRUST_PROXY=1

# ──────────────────────────────────────────────────────
# Rate limiting — backend de almacenamiento
# ──────────────────────────────────────────────────────
# En despliegues serverless (Vercel, Netlify, CF Workers) cada
# instancia tiene su propio Map en memoria → un atacante con N
# conexiones consigue N × límite. Configurar Upstash Redis (REST
# API, HTTP, sin connection pool) elimina ese bypass.
#
# Crear instancia gratuita en https://upstash.com/
# Si AMBAS variables están seteadas, el rate-limit usa Upstash;
# en otro caso usa el Map in-memory (con warning si NODE_ENV=production).
# UPSTASH_REDIS_REST_URL=https://xxx-yyy.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
#
# Opcional: prefijo de keys en Redis (default 'rl'). Útil si el
# mismo Redis sirve a varios entornos (staging + prod).
# RATE_LIMIT_KEY_PREFIX=rl

# ──────────────────────────────────────────────────────
# LLM — caché y cuotas
# ──────────────────────────────────────────────────────
# Cuota mensual de peticiones al asistente IA (voz + foto) por usuario.
# Cuando se alcanza, /api/voz/parse* devuelve 429 hasta el cambio de mes.
# Default: 500. Pon un valor alto (ej. 10000) o vacío para desactivar.
# LLM_QUOTA_MENSUAL_USUARIO=500

# TTL del caché de respuestas LLM (server/utils/llmCache.js). Si el
# usuario repite un texto idéntico dentro de este intervalo, se sirve
# la respuesta anterior sin gastar tokens. Default: 21600 (6h).
# LLM_CACHE_TTL_SECONDS=21600

# ──────────────────────────────────────────────────────
# Web Push (VAPID) — recordatorios push
# ──────────────────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY también se expone al cliente via public runtimeConfig.
# Si quedan vacías, el cron de recordatorios es un no-op silencioso.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ──────────────────────────────────────────────────────
# Cron — secreto para invocar endpoints protegidos
# ──────────────────────────────────────────────────────
# Los endpoints /api/cron/* requieren X-Cron-Secret en el header.
# Generar con: openssl rand -hex 32
CRON_SECRET=
