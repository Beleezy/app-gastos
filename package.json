{
  "name": "gastos",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:api": "playwright test --project=api",
    "test:e2e:ui": "playwright test --project=mobile --project=desktop",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:update-snapshots": "playwright test --project=visual --update-snapshots",
    "test:e2e:report": "playwright show-report",
    "security:audit": "npm audit --audit-level=high",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:apply": "node scripts/apply-migrations.mjs",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node server/database/seed.js",
    "db:seed:test": "node server/database/seed-test-data.js",
    "db:seed:test:user": "node server/database/seed-test-data.js",
    "db:seed:temp-users": "node server/database/seed-temp-users.js"
  },
  "dependencies": {
    "@nuxtjs/supabase": "^2.0.8",
    "@pinia/nuxt": "^0.11.3",
    "@vite-pwa/nuxt": "^1.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "nuxt": "^4.4.6",
    "pinia": "^3.0.4",
    "postgres": "^3.4.9",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "version": "1.0.0",
  "description": "Sistema de finanzas personales - PWA",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "vitest": "^4.1.6"
  }
